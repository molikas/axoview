# Server Storage Configuration
# Set to true to enable server-side storage for multi-device access
# Default is true - diagrams are saved to ./diagrams directory on the host
ENABLE_SERVER_STORAGE=true

# Git backup (optional)
# Set to true to automatically commit changes to git
ENABLE_GIT_BACKUP=false

# Storage path (inside container)
# This is mapped to ./diagrams on the host via Docker volume
STORAGE_PATH=/data/diagrams

# Backend port (usually doesn't need changing)
BACKEND_PORT=3001

# --- Authentication (STRONGLY recommended when storage is enabled) ---
# The API is UNAUTHENTICATED by default (AUTH_MODE=none). With server storage on,
# anyone who can reach the port can read, modify, and publicly share every
# diagram. That is fine ONLY for a loopback / trusted-LAN single-user setup —
# never expose an AUTH_MODE=none instance to an untrusted network.
# Set shared-token auth to require a bearer secret on every /api/* call:
#   AUTH_MODE=shared-token
#   AUTH_SHARED_SECRET=<a long random string>
AUTH_MODE=none

# --- CORS (browser cross-origin access to /api/*) ---
# In Docker/prod the app and API are same-origin (nginx fronts both), so no CORS
# is needed. Only `npm run dev` (SPA :3000 → backend :3001) is cross-origin, and
# that origin is allowed by default. Add extra allowed origins here (comma-
# separated) only if you serve the frontend from a different origin. Unknown
# origins get no CORS grant, which blocks drive-by requests from other websites.
# ALLOWED_ORIGINS=https://diagrams.example.com

# --- Public share links ---
# Base URL used to build /display/p/<uuid> share links. Set this to your public
# origin so links can't be poisoned via spoofed Host / X-Forwarded-Proto headers.
# Falls back to request headers when unset.
# PUBLIC_BASE_URL=https://diagrams.example.com

# --- Google Drive integration (Phase 3A/3B) — local dev only ---
# PUBLIC_GOOGLE_CLIENT_ID is the browser OAuth client ID: a PUBLIC identifier,
# NOT a secret (guarded by the authorized-origins allowlist, not by secrecy). It
# lets `npm run dev` on http://localhost:3000 start Google sign-in without a
# backend serving /api/config. rsbuild exposes PUBLIC_-prefixed vars to the
# browser bundle. Copy this line into a gitignored .env.local — the value is the
# same for every developer (it is the axoview project's client ID):
PUBLIC_GOOGLE_CLIENT_ID=485371025824-2ullp84i3nda2dgceirg9q87fvm36kl8.apps.googleusercontent.com
