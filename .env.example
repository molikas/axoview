# Server Storage Configuration
# Set to true to enable server-side storage for multi-device access
# Default is true - diagrams are saved to ./diagrams directory on the host
ENABLE_SERVER_STORAGE=true

# Git backup (optional)
# Set to true to automatically commit changes to git
ENABLE_GIT_BACKUP=false

# Storage path (inside container)
# This is mapped to ./diagrams on the host via Docker volume
STORAGE_PATH=/data/diagrams

# Backend port (usually doesn't need changing)
BACKEND_PORT=3001

# --- Google Drive integration (Phase 3A/3B) — local dev only ---
# PUBLIC_GOOGLE_CLIENT_ID is the browser OAuth client ID: a PUBLIC identifier,
# NOT a secret (guarded by the authorized-origins allowlist, not by secrecy). It
# lets `npm run dev` on http://localhost:3000 start Google sign-in without a
# backend serving /api/config. rsbuild exposes PUBLIC_-prefixed vars to the
# browser bundle. Copy this line into a gitignored .env.local — the value is the
# same for every developer (it is the axoview project's client ID):
PUBLIC_GOOGLE_CLIENT_ID=485371025824-2ullp84i3nda2dgceirg9q87fvm36kl8.apps.googleusercontent.com
