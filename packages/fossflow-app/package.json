{
  "name": "fossflow-app",
  "version": "1.10.8",
  "private": true,
  "description": "Progressive Web App for creating isometric diagrams",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@isoflow/isopacks": "^0.0.10",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "fossflow": "*",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.4",
    "react": "^19.2.4",
    "react-arborist": "^3.4.3",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.13.2",
    "web-vitals": "^5.2.0"
  },
  "scripts": {
    "prebuild": "node scripts/generateMaterialIconPack.js && cd ../.. && npm run build:lib",
    "prestart": "node scripts/generateMaterialIconPack.js",
    "start": "rsbuild dev",
    "build": "rsbuild build",
    "preview": "rsbuild preview",
    "clean": "rm -rf build",
    "test": "npx --no-install jest"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@rsbuild/core": "^1.7.5",
    "@rsbuild/plugin-react": "^1.4.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.4.9"
  }
}
